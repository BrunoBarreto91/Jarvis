# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@your-rds-endpoint:3306/jarvis

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=https://your-frontend-domain.vercel.app

# ─── n8n (Docker) ────────────────────────────────────────────────────────────
N8N_HOST=0.0.0.0
N8N_PORT=5678
WEBHOOK_URL=http://your-ec2-ip:5678/
DB_MYSQLDB_HOST=your-rds-endpoint.region.rds.amazonaws.com
DB_MYSQLDB_PORT=3306
DB_MYSQLDB_DATABASE=jarvis
DB_MYSQLDB_USER=admin
DB_MYSQLDB_PASSWORD=your-secure-password
